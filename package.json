{
  "name": "legendaeditor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "prebuild": "npm audit --audit-level=high",
    "preview": "vite preview",
    "preversion": "npm run build",
    "version": "git add -A",
    "postversion": "git push --follow-tags",
    "release": "npm version patch -m 'chore: release v%s'"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "autoprefixer": "10.5.0",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^1.14.0",
    "postcss": "8.5.13",
    "react": "^19.2.7",
    "react-dom": "^19.2.5",
    "tailwindcss": "3.4.19",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-build": "^7.4.1",
    "workbox-window": "^7.4.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.14"
  }
